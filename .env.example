# Duplicate this file to .env.local and add your Upstash Redis credentials
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# The domain used to prefix shortened links (defaults to host name if not defined)
NEXT_PUBLIC_SHORT_DOMAIN=tiny.to

